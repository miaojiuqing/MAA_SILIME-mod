{
    "task": [
        {
            "name": "日常-城镇对话",
            "entry": "日常-城镇对话-任务开始层",
            "label": "城镇对话",
            "description": "不点一下联盟盟友那边视角就是你没上线",
            "option": [
                "日常-城镇对话-自动处理战斗事件",
                "日常-城镇对话-自动处理交货事件"
            ]
        }
    ],
    "option": {
        "日常-城镇对话-自动处理战斗事件": {
            "type": "switch",
            "label": "自动处理战斗事件",
            "icon": "./resource/base/image/繁中/日常/城镇对话/特殊事件/双一览界面/战斗.png",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "日常-城镇对话-双一览处-有可处理事件-战斗": {
                            "enabled": true
                        },
                        "日常-城镇对话-城镇内-有可处理事件-战斗": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "日常-城镇对话-战斗-编队切换"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "日常-城镇对话-双一览处-有可处理事件-战斗": {
                            "enabled": false
                        },
                        "日常-城镇对话-城镇内-有可处理事件-战斗": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "日常-城镇对话-自动处理交货事件": {
            "type": "switch",
            "label": "自动处理交货事件",
            "icon": "./resource/base/image/繁中/日常/城镇对话/特殊事件/双一览界面/交货.png",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "日常-城镇对话-双一览处-有可处理事件-交货": {
                            "enabled": true
                        },
                        "日常-城镇对话-城镇内-有可处理事件-交货": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "日常-城镇对话-双一览处-有可处理事件-交货": {
                            "enabled": false
                        },
                        "日常-城镇对话-城镇内-有可处理事件-交货": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
