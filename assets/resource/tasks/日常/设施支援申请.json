{
    "task": [
        {
            "name": "日常-设施支援",
            "label": "设施支援",
            "entry": "设施支援-任务开始层",
            "description": "可以顺便把支援请求收了",
            "option": [
                "日常-设施支援-是否顺便收取支援申请奖励",
                "日常-设施支援-是否顺便收取设施产出奖励"
            ]
        }
    ],
    "option": {
        "日常-设施支援-是否顺便收取支援申请奖励": {
            "type": "switch",
            "label": "是否顺便收取支援申请奖励",
            "description": "就是点进“支援”的时候左边那个",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "设施支援-无来自盟友的支援请求": {
                            "recognition": {
                                "type": "ColorMatch",
                                "param": {
                                    "roi": [
                                        138,
                                        584,
                                        268,
                                        72
                                    ],
                                    "upper": [
                                        57,
                                        57,
                                        59
                                    ],
                                    "lower": [
                                        15,
                                        14,
                                        16
                                    ],
                                    "count": 8000
                                }
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "设施支援-无来自盟友的支援请求": {
                            "recognition": "DirectHit"
                        }
                    }
                }
            ]
        },
        "日常-设施支援-是否顺便收取设施产出奖励": {
            "type": "switch",
            "label": "顺便收取设施产出",
            "description": "只有检查到MAX了才会收取",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "设施支援-设施产出已达上限": {
                            "enabled": true
                        },
                        "设施产出领取-生产物品合计确认": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "设施支援-设施产出已达上限": {
                            "enabled": false
                        },
                        "设施产出领取-生产物品合计确认": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
