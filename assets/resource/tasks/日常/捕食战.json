{
    "task": [
        {
            "name": "日常-捕食战",
            "label": "捕食战",
            "entry": "日常捕食-任务开始层",
            "description": "不会有人没解锁上级捕食战吧(",
            "option": [
                "日常捕食-自行切换至上级难度",
                "日常捕食-捕食类型选择",
                "日常捕食-编队选择",
                "日常捕食-编队切换方式"
            ]
        }
    ],
    "option": {
        "日常捕食-自行切换至上级难度": {
            "label": "自行切换至上级难度",
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "日常捕食-点击进入捕食类型选择界面": {
                            "next": [
                                "日常捕食-当前选中难度为上级",
                                "日常捕食-点击进入捕食类型选择界面",
                                "[JumpBack]日常捕食-点击选择上级难度"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "日常捕食-点击进入捕食类型选择界面": {
                            "next": [
                                "日常捕食-正处于捕食类型选择界面",
                                "日常捕食-点击进入捕食类型选择界面"
                            ]
                        }
                    }
                }
            ]
        },
        "日常捕食-捕食类型选择": {
            "type": "select",
            "label": "捕食类型选择",
            "cases": [
                {
                    "name": "日常捕食-转魂",
                    "label": "转魂",
                    "pipeline_override": {
                        "日常捕食-点击进入关卡": {
                            "template": [
                                "繁中/日常/捕食战/捕食类型-转魂.png"
                            ]
                        }
                    }
                },
                {
                    "name": "日常捕食-心体",
                    "label": "心体",
                    "pipeline_override": {
                        "日常捕食-点击进入关卡": {
                            "template": [
                                "繁中/日常/捕食战/捕食类型-心体.png"
                            ]
                        }
                    }
                },
                {
                    "name": "日常捕食-坚守",
                    "label": "坚守",
                    "pipeline_override": {
                        "日常捕食-点击进入关卡": {
                            "template": [
                                "繁中/日常/捕食战/捕食类型-坚守.png"
                            ]
                        }
                    }
                },
                {
                    "name": "日常捕食-猛攻",
                    "label": "猛攻",
                    "pipeline_override": {
                        "日常捕食-点击进入关卡": {
                            "template": [
                                "繁中/日常/捕食战/捕食类型-猛攻.png"
                            ]
                        }
                    }
                }
            ]
        },
        "日常捕食-编队选择": {
            "type": "select",
            "label": "编队选择",
            "cases": [
                {
                    "name": "不切换",
                    "pipeline_override": {
                        "日常捕食-成功切换至所选编队": {
                            "recognition": "DirectHit"
                        }
                    }
                },
                {
                    "name": "第一编队",
                    "pipeline_override": {
                        "日常捕食-成功切换至所选编队": {
                            "expected": [
