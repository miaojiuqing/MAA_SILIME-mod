                },
                {
                    "name": "第八编队",
                    "pipeline_override": {
                        "日常捕食-成功切换至所选编队": {
                            "expected": [
                                "八.*"
                            ]
                        }
                    }
                },
                {
                    "name": "第九编队",
                    "pipeline_override": {
                        "日常捕食-成功切换至所选编队": {
                            "expected": [
                                "九.*"
