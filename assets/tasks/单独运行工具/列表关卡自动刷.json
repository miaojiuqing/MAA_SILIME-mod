{
    "task": [
        {
            "name": "单线程工具-刷关",
            "label": "列表刷关",
            "entry": "列表刷关-任务开始层",
            "description": "目前仅支持剧情、捕食类",
            "option": [
                "列表刷关-主线模式",
                "通用-体力不足处理",
                "列表刷关-战斗类编队选择",
                "通用-编队切换方式"
            ]
        }
    ],
    "preset": [],
    "option": {
        "列表刷关-主线模式": {
            "type": "switch",
            "label": "主线模式",
            "default_case": "No",
            "description": "启动后列表刷完会检查是否为上级,若不是则初->中->上的顺序挑战",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "列表刷关-当前列表已挑战完毕": {
                            "focus": {
                                "Node.Recognition.Succeeded": "目标所及关卡已刷完,已开启主线模式,将检查当前章节难度"
                            }
                        },
                        "列表刷关-主线模式-章节难度检查": {
                            "enabled": true
                        }
                    },
                    "description": "不在关卡列表启动该功能时,将会直接开始自行寻找主线讨伐",
                    "option": [
                        "列表刷关-主线模式-章节选择"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "列表刷关-当前列表已挑战完毕": {
                            "focus": {
                                "Node.Recognition.Succeeded": "目标所及关卡已刷完"
                            },
                            "next": []
                        },
                        "列表刷关-主线模式-章节难度检查": {
                            "enabled": false
                        },
                        "章节选择-任务开始层": {
                            "enabled": false
                        },
                        "章节选择-总任务层": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
