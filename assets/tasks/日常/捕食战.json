{
    "task": [
        {
            "name": "日常-捕食战",
            "label": "捕食战",
            "entry": "日常捕食-任务开始层",
            "group": [
                "日常"
            ],
            "default_check": true,
            "description": "不会有人没解锁上级捕食战吧(",
            "option": [
                "日常捕食-自行切换至上级难度",
                "日常捕食-捕食类型选择",
                "日常捕食-编队选择",
                "通用-编队切换方式"
            ],
            "pipeline_override": {
                "异常处理-日期更新": {
                    "next": [
                        "日常捕食-任务开始层"
                    ]
                }
            }
        }
    ],
    "preset": [],
    "option": {
        "日常捕食-自行切换至上级难度": {
            "label": "自行切换至上级难度",
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "日常捕食-点击进入捕食类型选择界面": {
                            "next": [
                                "日常捕食-当前选中难度为上级",
                                "日常捕食-点击进入捕食类型选择界面",
                                "[JumpBack]日常捕食-点击选择上级难度"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "日常捕食-点击进入捕食类型选择界面": {
                            "next": [
                                "日常捕食-正处于捕食类型选择界面",
                                "日常捕食-点击进入捕食类型选择界面"
                            ]
                        }
                    }
                }
            ]
        },
        "日常捕食-捕食类型选择": {
