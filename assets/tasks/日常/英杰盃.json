        "英杰盃-挑战卷管理": {
            "label": "挑战卷耗尽后动作",
            "type": "select",
            "default_case": "结束任务返回主菜单",
            "cases": [
                {
                    "name": "结束任务返回主菜单",
                    "pipeline_override": {
                        "英杰盃-挑战卷已耗尽": {
                            "action": {
                                "type": "Click",
                                "param": {
                                    //叉叉
                                    "target": [
                                        1169,
                                        149,
                                        27,
                                        39
                                    ]
                                }
                            },
                            "focus": {
                                "Node.Recognition.Succeeded": "挑战卷不足,将结束任务返回主菜单"
                            },
                            "next": [
                                "成功进入主菜单",
                                "英杰盃-挑战卷已耗尽",
