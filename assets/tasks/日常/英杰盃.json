                    "option": [
                        "英杰盃-自动领取功绩奖励"
                    ]
                },
                {
                    "name": "使用英杰盃参加卷继续战斗",
                    "description": "耗尽了的情况未考虑，待投稿",
                    "pipeline_override": {
                        "英杰盃-挑战卷已耗尽": {
                            "action": {
                                "type": "Click",
                                "param": {
                                    //点击YES准备回复
                                    "target": [
                                        664,
                                        476,
                                        219,
                                        73
                                    ]
                                }
                            },
                            "focus": {
                                "Node.Recognition.Succeeded": "挑战卷不足,将使用英杰盃参与卷进行一次回复"
                            },
                            "next": [
                                "英杰盃-挑战卷耗尽-已打开回复选择方式界面",
                                "英杰盃-挑战卷已耗尽"
                            ]
                        }
                    }
                }
            ]
        },
        "英杰盃-自动领取功绩奖励": {
            "type": "switch",
            "label": "自行领取功绩奖励",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "英杰盃-挑战卷已耗尽": {
                            "next": [
                                "英杰盃-功绩领取-已回到一般战界面",
                                "英杰盃-挑战卷已耗尽",
                                "[JumpBack]英杰盃-功绩领取-处于编队界面点击左上角返回",
                                "[JumpBack]通用-可处理范围加载等待"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": { //保持"挑战卷管理"的选择逻辑
                        "英杰盃-挑战卷已耗尽": {}
