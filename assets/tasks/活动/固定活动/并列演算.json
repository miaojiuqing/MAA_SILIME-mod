{
    "task": [
        {
            "name": "并列演算",
            "entry": "并列演算-任务开始层",
            "default_check": true,
            "group": [
                "日常"
            ],
            "description": "请自行解锁,固定点击MAX并列最大次数",
            "option": [
                "活动并列演算-编队选择",
                "活动并列演算-自动编队",
                "通用-编队切换方式",
                "通用-有未完成的并列演算"
                // "并列演算-战斗模式"
            ]
        }
    ],
    "option": {
        "活动并列演算-编队选择": {
            "type": "select",
            "label": "编队选择",
            "cases": [
                {
                    "name": "不切换",
                    "pipeline_override": {
                        "并列演算-已成功切换至所选编队": {
                            "recognition": "DirectHit"
                        }
                    }
                },
                {
                    "name": "第一编队",
                    "pipeline_override": {
                        "并列演算-已成功切换至所选编队": {
                            "expected": [
                                "一.*"
                            ]
                        }
                    }
                },
                {
                    "name": "第二编队",
                    "pipeline_override": {
