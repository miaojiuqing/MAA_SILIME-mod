                            ]
                        }
                    }
                },
                {
                    "name": "第五编队",
                    "pipeline_override": {
                        "并列演算-已成功切换至所选编队": {
                            "expected": [
                                "五.*"
                            ]
                        }
                    }
                },
                {
                    "name": "第六编队",
                    "pipeline_override": {
                        "并列演算-已成功切换至所选编队": {
                            "expected": [
                                "六.*"
                            ]
                        }
                    }
                },
                {
                    "name": "第七编队",
                    "pipeline_override": {
                        "并列演算-已成功切换至所选编队": {
                            "expected": [
                                "七.*"
                            ]
                        }
                    }
                },
                {
                    "name": "第八编队",
                    "pipeline_override": {
