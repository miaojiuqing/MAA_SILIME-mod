                                "二.*"
                            ]
                        }
                    }
                },
                {
                    "name": "第三编队",
                    "pipeline_override": {
                        "并列演算-已成功切换至所选编队": {
                            "expected": [
                                "三.*"
                            ]
                        }
                    }
                },
                {
