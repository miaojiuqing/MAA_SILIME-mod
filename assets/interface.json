{
    // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
    // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
    "interface_version": 2,
    "name": "辛西娅小助手重构版",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "contact": "QQ群: 123456789",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MAA!",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/MaaXYZ/MaaPracticeBoilerplate",
    "version": "1.0.0",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720 // 默认缩放分辨率的短边长度
        },
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "Visual Studio",
                // 截图及控制方式，请根据项目实际情况修改
                // 文档: https://maafw.xyz/docs/2.4-ControlMethods
                "screencap": "PrintWindow", // 截图方式
                "mouse": "PostMessageWithCursorPos", // 鼠标控制方式
                "keyboard": "PostMessageWithCursorPos" // 键盘控制方式
            }
        }
    ], //发版试验
    "resource": [
        {
            "name": "繁中",
            "path": [
                "./resource"
            ]
        }
        // {
        //     "name": "日服",
        //     "path": [
        //         "./resource"
        //         // "./resource_bilibili"
        //     ]
        // }
    ],
    "task": [],
    "import": [
        "tasks/启动游戏.json",
        "tasks/日常/锻造升级.json",
        "tasks/日常/日常送礼.json",
        "tasks/日常/设施支援申请.json",
        "tasks/日常/城镇对话.json", //可优化，分两阶段，第二阶段的一览检查不加点击动作专门处理特殊事件
        "tasks/日常/捕食战.json",
        "tasks/商店/贸易.json", //待补充商品
        "tasks/琐事/泡温泉.json",
        "tasks/琐事/联盟.json",
        "tasks/琐事/设施产出收取.json",
        "tasks/琐事/好友设施支援.json",
        "tasks/活动/奖励关/魔王龙道.json",
        "tasks/活动/固定活动/活动捕食战.json", //饼
        "tasks/活动/固定活动/并列演算.json",
        "tasks/日常/奖励领取/任务奖励.json",
        "tasks/日常/奖励领取/果盘奖励领取.json",
        "tasks/日常/奖励领取/邮箱.json",
        "tasks/日常/英杰盃.json",
        "tasks/单独运行工具/盖德监工.json", //饼
        "tasks/单独运行工具/单本复刷.json",
        "tasks/关闭游戏.json"
    ],
    "preset": [],
    "option": {
        "通用-编队切换方式": {
            "type": "select",
            "label": "编队切换方式",
            "default_case": "点击切换至下一个",
            "cases": [
                {
                    "name": "点击切换至下一个",
                    "description": "点右边",
                    "pipeline_override": {
                        "通用-编队切换-点击切换编队": {
                            "recognition": {
                                "type": "TemplateMatch",
                                "param": {
                                    "roi": [
                                        1127,
                                        298,
                                        128,
                                        128
                                    ],
                                    "template": [
                                        "繁中/通用/战斗/切换编队-右.png"
                                    ]
                                }
                            }
                        }
                    }
                },
                {
                    "name": "点击切换至上一个",
                    "description": "点左边",
                    "pipeline_override": {
                        "通用-编队切换-点击切换编队": {
                            "recognition": {
                                "type": "TemplateMatch",
                                "param": {
                                    "roi": [
                                        17,
                                        305,
                                        129,
                                        114
                                    ],
                                    "template": [
                                        "繁中/通用/战斗/切换编队-左.png"
                                    ]
                                }
                            }
                        }
                    }
                }
            ]
        }
    }
}
